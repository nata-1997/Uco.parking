# Copia este archivo a .env en esta misma carpeta (docker/strapi/.env):
#   copy env.example .env   (Windows)
#   cp env.example .env       (Linux/macOS)
#
# La contraseña debe coincidir con la que uses al crear el proyecto Strapi (--dbpassword)
# y con POSTGRES_PASSWORD del servicio strapiDB (interpolación de Docker Compose).

DATABASE_PASSWORD=cambiar_por_una_contrasena_segura

# --- Secretos de Strapi (obligatorios; genera valores aleatorios) ---
# APP_KEYS: varias claves separadas por coma (p. ej. openssl rand -base64 32)
APP_KEYS=clave1Generar,clave2Generar
API_TOKEN_SALT=generar_aleatorio
ADMIN_JWT_SECRET=generar_aleatorio
TRANSFER_TOKEN_SALT=generar_aleatorio
JWT_SECRET=generar_aleatorio
# ENCRYPTION_KEY: en Strapi 5 suele pedirse una clave larga para cifrar secretos en BD
ENCRYPTION_KEY=generar_clave_larga_minimo_32_caracteres

NODE_ENV=development
