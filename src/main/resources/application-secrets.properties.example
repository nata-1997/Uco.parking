# Copia a application-secrets.properties (ignorado por git).
#
# SSMS:
#   Servidor:      localhost,1433
#   Autenticación: SQL Server Authentication
#   Usuario:       sa
#
# Contraseña según cómo creaste SQL Server:
#   Docker (MSSQL_SA_PASSWORD):  TuPassword#123  →  escribe: TuPassword\#123
#   Manual / otra:               TuPassword123!  →  escribe: TuPassword123!

spring.datasource.username=sa
spring.datasource.password=TuPassword\#123
