# Copia este archivo a application-secrets.properties (ignorado por git).
# Valores de ejemplo para SQL Server 2022 en Docker (MSSQL_SA_PASSWORD=TuPassword#123).
# Crea la base si hace falta: CREATE DATABASE UCOParking;
#
# Si la contraseña contiene #, escápala con barra invertida en .properties.
spring.datasource.url=jdbc:sqlserver://localhost:1433;databaseName=UCOParking;encrypt=true;trustServerCertificate=true
spring.datasource.username=sa
spring.datasource.password=TuPassword\#123
