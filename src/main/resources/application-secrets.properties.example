# Copia este archivo a la RAÍZ del proyecto como application-secrets.properties
# (no dentro de src/main/resources). Ese archivo está en .gitignore.
#
# El perfil dev importa: optional:file:./application-secrets.properties
#
# Opcional: si usas un ".env" en la raíz (p. ej. exportado desde Infisical), la app lo carga
# al arrancar; las variables de entorno del SO y este archivo siguen teniendo prioridad según el caso.
#
# SSMS / Docker típico:
#   Servidor:      localhost,1433
#   Usuario:       sa
#   Contraseña:    la misma que MSSQL_SA_PASSWORD en docker-compose
#
# Ejemplo (reemplaza por tu contraseña local; no subas este archivo con secretos reales):
# spring.datasource.username=sa
# spring.datasource.password=TU_PASSWORD_SA
#
# Si la contraseña contiene `#`, en .properties escápalo: p. ej. MiClave\#123
#
# --- SendGrid (correo al reservar cupo) ---
# Crea una API Key en SendGrid y verifica el remitente (Single Sender o dominio del correo institucional / Outlook).
# SENDGRID_ENABLED=false desactiva el envío (útil en local sin clave).
# sendgrid.enabled=false
# sendgrid.api-key=SG.xxxxxxxxxxxxx
# sendgrid.from-email=no-reply@tudominio.edu.co
# sendgrid.from-name=UcoParking
