# Copia este archivo a la RAÍZ del proyecto como application-secrets.properties
# (no dentro de src/main/resources). Ese archivo está en .gitignore.
#
# El perfil dev importa: optional:file:./application-secrets.properties
#
# SSMS / Docker típico:
#   Servidor:      localhost,1433
#   Usuario:       sa
#   Contraseña:    la misma que MSSQL_SA_PASSWORD en docker-compose
#
# Ejemplo (descomenta y ajusta):
# spring.datasource.username=sa
# spring.datasource.password=TuPassword#123
#
# Auth0 (JWT resource server; mismo tenant/audience que el SPA):
# spring.security.oauth2.resourceserver.jwt.issuer-uri=https://TU-TENANT.auth0.com/
# spring.security.oauth2.resourceserver.jwt.audiences=https://identificador-de-tu-api-en-auth0
