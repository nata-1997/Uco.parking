# Compiled class file
*.class

# Maven
target/

# Secretos locales (tu compañera usa los suyos en copias locales, no en Git)
application-secrets.properties
.env
.env.local
.env.development.local
!.env.example

# Secretos reales exportados para Infisical / import local (no subir)
infisical-dev.env
secrets.local.env

# Infisical CLI: enlace local al proyecto (plantilla: .infisical.json.example)
.infisical.json

# Log file
*.log

# Copias de seguridad SQL locales (nunca subir a Git)
backups/*.bak

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*
/.idea/.gitignore
/.idea/compiler.xml
/.idea/encodings.xml
/.idea/jarRepositories.xml
/.idea/misc.xml
/.idea/vcs.xml
