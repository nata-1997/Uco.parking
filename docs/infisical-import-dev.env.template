# Plantilla de nombres de secretos (entorno dev en Infisical). Los valores reales viven solo en Infisical.
# No rellenes este archivo con secretos ni lo subas a Git.

# --- Frontend (Vue) ---
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=
VITE_DEV_API_PROXY_TARGET=
# VITE_API_BASE_URL=

# --- Backend (Spring Boot) ---
# SPRING_DATASOURCE_URL debe ser JDBC completo, p. ej.:
# jdbc:sqlserver://localhost:1433;databaseName=UCOParking;encrypt=true;trustServerCertificate=true
# (no pongas solo host:puerto como localhost:1433)
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
# Opcional
# AUTH0_ISSUER_URI=
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=

# --- Kong / Docker ---
KONG_PG_PASSWORD=
KONG_DB_NAME=kong
# KONG_PG_USER=kong

# --- SQL Server (perfil sql del compose) ---
MSSQL_SA_PASSWORD=

# --- WAF ModSecurity (opcional, perfil waf en docker-compose-kong.yml) ---
# No son secretos: solo si quieres centralizar ajustes en Infisical. Si las omites, Compose usa valores por defecto.
# MODSEC_RULE_ENGINE=DetectionOnly
# BLOCKING_PARANOIA=1
# WAF_HOST_PORT=9080
# VITE_DEV_API_PROXY_TARGET con WAF: http://127.0.0.1:9080 (URL pública local, no es contraseña)
