# Copia este archivo a `.env` en la raíz de Uco.parking (el archivo `.env` no se sube a Git).
# Misma contraseña que uses aquí debe ir en `application-secrets.properties` (spring.datasource.password).
#
# Si la contraseña contiene `#`, en `.env` ponla entre comillas dobles, p. ej. MSSQL_SA_PASSWORD="TuPass#123"

MSSQL_SA_PASSWORD=

# --- Auth0 (Spring no lee .env automáticamente; define estas variables en el sistema o en Run Configuration) ---
# AUTH0_ISSUER_URI=https://tu-tenant.us.auth0.com/
# AUTH0_AUDIENCE=https://identificador-de-tu-api-en-auth0

# --- Kong (solo si usas docker-compose-kong.yml): URL del Spring Boot visto desde el contenedor Kong ---
# Por defecto el compose ya usa host.docker.internal:8080; cámbialo si tu API corre en otro puerto/host.
# UCOPARKING_UPSTREAM=http://host.docker.internal:8080
