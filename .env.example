# Uco.parking — secretos solo desde Infisical (o variables de entorno equivalentes).
#
# No copies contraseñas a archivos locales en esta rama de trabajo: usa la CLI:
#   infisical run --env=dev -- .\mvnw.cmd spring-boot:run
#   infisical run --env=dev -- docker compose -f docker-compose-kong.yml up -d
#
# Scripts: scripts/run-spring-dev.ps1 | scripts/run-kong.ps1
# Lista de claves: docs/infisical-import-dev.env.template y docs/INFISICAL_UCOPARKING.md
#
# Docker Compose (solo sustitución de variables en el host) puede leer un `.env` en la raíz
# si exportas antes los valores; el flujo recomendado es `infisical run` sin guardar secretos en disco.
#
# =============================================================================
# Plantilla opcional si usas .env local (copia a ".env"; ".env" está en .gitignore)
# =============================================================================
# La aplicación carga ".env" al arrancar si existe; Spring no pisa variables ya definidas en el SO.
#
# --- Docker SQL Server ---
# MSSQL_SA_PASSWORD=
#
# --- Base de datos (opción A: Spring estándar) ---
# SPRING_DATASOURCE_URL=jdbc:sqlserver://localhost:1433;databaseName=UCOParking;encrypt=true;trustServerCertificate=true
# SPRING_DATASOURCE_USERNAME=sa
# SPRING_DATASOURCE_PASSWORD=
#
# --- Base de datos (opción B: DB_*) ---
# DB_HOST=localhost
# DB_PORT=1433
# DB_NAME=UCOParking
# DB_USERNAME=sa
# DB_PASSWORD=
#
# --- Auth0 ---
# AUTH0_ISSUER_URI=https://TU-TENANT.auth0.com/
# AUTH0_AUDIENCE=https://identificador-de-tu-api-en-auth0
#
# --- SendGrid (notificación al reservar cupo) ---
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=no-reply@tudominio.edu.co
# SENDGRID_FROM_NAME=UcoParking
# SENDGRID_ENABLED=true
#
# --- Redis / Valkey ---
# REDIS_HOST=localhost
# REDIS_PORT=6380
#
# --- Key Vault ---
# AZURE_KEYVAULT_ENABLED=false
# AZURE_KEYVAULT_URI=

# --- Strapi (CMS: mensajes API, textos UI, correo; ver docs/STRAPI.md) ---
# Strapi en la máquina con "npm run develop" (típico puerto 1337). En Windows conviene 127.0.0.1.
# STRAPI_URL=http://127.0.0.1:1337
# STRAPI_API_TOKEN=
# STRAPI_REMOTE_ENABLED=true
# STRAPI_FAIL_ON_STARTUP=false
# STRAPI_REFRESH_MS=300000
# STRAPI_COLLECTION_API=mensaje-apis
# STRAPI_COLLECTION_UI=mensaje-uis

# --- Jaeger / OpenTelemetry (trazas OTLP; ver docs/JAEGER.md) ---
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# TRACE_SAMPLE_PROBABILITY=0.1
