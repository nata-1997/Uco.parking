# =============================================================================
# UcoParking API — plantilla de secretos (raíz del repo, junto a pom.xml)
# =============================================================================
# Copia a ".env" y rellena. El archivo ".env" está en .gitignore.
#
# Origen típico: exportar desde Infisical (formato .env) y completar lo que falte.
# La aplicación carga ".env" al arrancar (ver UcoParkingApplication); Spring no
# pisa variables que ya existan en el SO o en la Run Configuration de IntelliJ.
#
# Líneas con # al inicio son comentarios; quita el # y asigna valor donde toque.
# =============================================================================

# --- Docker SQL Server (obligatorio para: docker compose up -d) ---
MSSQL_SA_PASSWORD=

# --- Base de datos (opción A: como en Infisical / Spring estándar) ---
# SPRING_DATASOURCE_URL=jdbc:sqlserver://localhost:1433;databaseName=UCOParking;encrypt=true;trustServerCertificate=true
# SPRING_DATASOURCE_USERNAME=sa
# SPRING_DATASOURCE_PASSWORD=

# --- Base de datos (opción B: variables DB_* si no usas SPRING_DATASOURCE_*) ---
# DB_HOST=localhost
# DB_PORT=1433
# DB_NAME=UCOParking
# DB_USERNAME=sa
# DB_PASSWORD=

# --- Auth0 (JWT del API) ---
# AUTH0_ISSUER_URI=https://TU-TENANT.auth0.com/
# AUTH0_AUDIENCE=https://identificador-de-tu-api-en-auth0

# --- SendGrid (notificación al reservar cupo) ---
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=no-reply@tudominio.edu.co
# SENDGRID_FROM_NAME=UcoParking
# SENDGRID_ENABLED=true

# --- Redis / Valkey (docker-compose expone 6380) ---
# REDIS_HOST=localhost
# REDIS_PORT=6380

# --- Key Vault (solo despliegue Azure; en local suele desactivado) ---
# AZURE_KEYVAULT_ENABLED=false
# AZURE_KEYVAULT_URI=

# --- Kong / front (este backend no las usa; útiles si compartes .env con el monorepo) ---
# UCOPARKING_UPSTREAM=http://host.docker.internal:8080
# VITE_API_URL=
# VITE_AUTH0_AUDIENCE=
